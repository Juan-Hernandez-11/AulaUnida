# ========================================
# DATABASE (Railway PostgreSQL)
# ========================================
DATABASE_URL=postgresql://user:password@railway.railway.internal:5432/aulaunida

# ========================================
# FIREBASE
# ========================================
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key_admin
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# ========================================
# JWT & SECURITY
# ========================================
JWT_SECRET=your_jwt_secret_key_min_32_chars

# ========================================
# API URLS
# ========================================
# Para Railway (Backend)
API_URL=https://aulaunida-api.railway.app

# Para Vercel (usará esta variable)
NEXT_PUBLIC_API_URL=https://aulaunida-api.railway.app

# ========================================
# NODE ENVIRONMENT
# ========================================
NODE_ENV=production

# ========================================
# NEXT.JS
# ========================================
NEXT_PUBLIC_BASE_URL=https://aulaunida.vercel.app
